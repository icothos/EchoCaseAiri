{
    "name": "@proj-airi/gemini-utils",
    "type": "module",
    "version": "0.1.0",
    "private": true,
    "description": "Shared @google/genai utilities (instance cache, streaming, token counting)",
    "license": "MIT",
    "exports": {
        ".": {
            "import": "./src/index.ts",
            "types": "./src/index.ts"
        }
    },
    "scripts": {
        "build": "tsdown src/index.ts --format esm --dts",
        "dev": "tsdown src/index.ts --format esm --dts --watch",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@google/genai": "catalog:"
    },
    "devDependencies": {
        "tsdown": "catalog:",
        "typescript": "~5.9.3"
    }
}