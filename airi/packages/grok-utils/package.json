{
    "name": "@proj-airi/grok-utils",
    "type": "module",
    "version": "0.1.0",
    "private": true,
    "description": "Shared xAI Grok utilities (streaming API wrapper, token parsing, observability hooks)",
    "license": "MIT",
    "exports": {
        ".": {
            "import": "./src/index.ts",
            "types": "./src/index.ts"
        }
    },
    "scripts": {
        "build": "tsdown src/index.ts --format esm --dts",
        "dev": "tsdown src/index.ts --format esm --dts --watch",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@ai-sdk/xai": "catalog:",
        "ai": "catalog:"
    },
    "devDependencies": {
        "tsdown": "catalog:",
        "typescript": "~5.9.3"
    }
}
